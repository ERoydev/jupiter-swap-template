# Solana RPC endpoint
# Public mainnet endpoint for development. For production, use Helius/QuickNode/Triton.
VITE_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Jupiter Swap API v2 base URL
VITE_JUPITER_API_URL=https://api.jup.ag/swap/v2

# Jupiter API key (required for all requests)
# Get yours at https://portal.jup.ag
VITE_JUPITER_API_KEY=your_api_key_here
