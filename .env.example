# Solana RPC endpoint
# Public mainnet endpoint for development. For production, use Helius/QuickNode/Triton.
VITE_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Jupiter API root URL. Paths like /swap/v2/order, /tokens/v2/search, /ultra/v1/balances
# are prefixed in code — do NOT include the path suffix here.
VITE_JUPITER_API_URL=https://api.jup.ag

# Jupiter API key — OPTIONAL in development.
# /tokens/v2/* and /ultra/v1/* fall back to lite-api.jup.ag when this is absent.
# REQUIRED for swap execution (/swap/v2/*). Get one at https://portal.jup.ag
VITE_JUPITER_API_KEY=
